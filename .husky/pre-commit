npx lint-staged

# Run Go tests if any .go files are staged
if git diff --cached --name-only | grep -q '\.go$'; then
  echo "Running go vet..."
  go vet ./...
  echo "Running staticcheck..."
  staticcheck -tests=false -go 1.26 ./...
  echo "Running go test..."
  go test -count=1 -timeout 120s ./...
fi
