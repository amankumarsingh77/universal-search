{
  "name": "findo",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.go": [
      "goimports -w",
      "bash -c 'go vet ./...'",
      "bash -c 'staticcheck -tests=false -go 1.26 ./...'"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --fix \"$@\"' --"
    ]
  }
}
